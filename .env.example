# Auth — NextAuth.js
# Generate secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=replace-with-32-byte-random-string
NEXTAUTH_URL=https://your-domain.com

# GitHub OAuth — create app: https://github.com/settings/applications/new
# Authorization callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# Comma-separated whitelist of GitHub emails allowed to access /admin
# If empty, defaults to ihor.metelskyi@gmail.com
ALLOWED_EMAILS=ihor.metelskyi@gmail.com

# Comma-separated whitelist of GitHub usernames (lowercase, no @) allowed to access /admin
# More reliable than email — works even if GitHub email is unverified.
# If empty, defaults to: metelskyi
ALLOWED_GITHUB_LOGINS=metelskyi,Metelskyi91

# Vercel deploy hook (optional) — Project Settings → Git → Deploy Hooks
# Triggers a redeploy when admin clicks "Publish"
VERCEL_DEPLOY_HOOK=

# GitHub repo for cv.json commits from admin panel
# Create a Fine-grained PAT: Settings → Developer settings → Personal access tokens → Fine-grained tokens
# Repository access: Only select repositories → your repo
# Permissions: Contents = Read and write
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=living-cv
GITHUB_REPO_BRANCH=main
GITHUB_REPO_TOKEN=github_pat_xxx...

# Public URL used for absolute links and PDF generation target
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: local Chrome path for /api/export-pdf in development.
# On Vercel, the homepage's "Save as PDF" button uses the browser's
# built-in window.print() (no server-side PDF needed).
# This route still works locally when PUPPETEER_EXECUTABLE_PATH is set.
PUPPETEER_EXECUTABLE_PATH=
